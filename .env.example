# PromForge — environment template. Copy to .env and fill in values.
NODE_ENV=development
PORT=3000

# Postgres connection string for the Supabase project (use the *pooled* connection).
# Get it from: Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgres://postgres.etasxbaorwgjoofdxean:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# JWT signing secret. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Gemini proxy via Supabase Edge Function. The GEMINI_API_KEY itself lives in the
# Edge Function secrets — Node never sees it.
SUPABASE_URL=https://etasxbaorwgjoofdxean.supabase.co
SUPABASE_ANON_KEY=sb_publishable_v9Hxgl906_7egC7Nim0MdQ_jN54qu5G
GEMINI_FUNCTION_NAME=gemini-search

# Admin bootstrap (used by `npm run bootstrap` to ensure the admin account exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1124
